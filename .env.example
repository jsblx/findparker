# All variables below are optional for local dev. With none set, the app runs fully
# offline against InMemoryProvider and a keyless map fallback (added in a later slice).

# Supabase project URL. When set (together with the anon key), the app uses
# SupabaseProvider instead of InMemoryProvider.
VITE_SUPABASE_URL=

# Supabase anonymous/public API key.
VITE_SUPABASE_ANON_KEY=

# MapTiler API key for higher-quality basemap tiles. Falls back to a keyless
# basemap style when unset.
VITE_MAPTILER_KEY=
